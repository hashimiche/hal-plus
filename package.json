{
  "name": "hal-plus",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:all",
    "dev:all": "concurrently \"npm run dev:api\" \"npm run dev:ui:wait\"",
    "dev:ui": "vite",
    "dev:ui:wait": "wait-on tcp:127.0.0.1:9001 && npm run dev:ui",
    "dev:api": "node --watch server/index.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "node server/index.mjs"
  },
  "dependencies": {
    "concurrently": "^9.0.1",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.4",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.8",
    "wait-on": "^8.0.1"
  }
}
